# Thai Binh University Training Platform - Environment Configuration
# Copy this file to .env and update the secrets

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Local development
DATABASE_URL=postgresql://thai_binh:thai_binh_dev@localhost:5432/thai_binh_training

# Docker development (if using docker-compose)
# DATABASE_URL=postgresql://thai_binh:thai_binh_dev@postgres:5432/thai_binh_training

# Database credentials
DB_USER=thai_binh
DB_PASSWORD=thai_binh_dev
DB_NAME=thai_binh_training
DB_PORT=5432

# Connection pool settings
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================
# Authentication (Better-Auth)
# ============================================
# IMPORTANT: Change this in production!
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-must-be-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:8000

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# ============================================
# API Gateway Configuration
# ============================================
GATEWAY_PORT=8000

# Rate Limits (requests per minute)
ADMIN_RATE_LIMIT=200
TEACHER_RATE_LIMIT=300
STUDENT_RATE_LIMIT=500

# Request Timeout (milliseconds)
REQUEST_TIMEOUT=30000

# ============================================
# Service URLs (for local development)
# ============================================
ADMIN_BFF_URL=http://localhost:3001
TEACHER_BFF_URL=http://localhost:3002
STUDENT_BFF_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004
COURSE_SERVICE_URL=http://localhost:3005
ENROLLMENT_SERVICE_URL=http://localhost:3006
CERTIFICATION_SERVICE_URL=http://localhost:3007
FINANCE_SERVICE_URL=http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3009

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8000

# ============================================
# VNPay Payment Gateway Configuration
# ============================================
# Sandbox credentials from https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=TEST12345
VNPAY_SECURE_SECRET=your-vnpay-secret-key-here
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_RETURN_URL=http://localhost:3008/api/payments/vnpay-return
VNPAY_IPN_URL=http://localhost:3008/api/payments/vnpay-ipn

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Feature Flags
# ============================================
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_RATE_LIMITING=true
