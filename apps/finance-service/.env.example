# Finance Service Environment Configuration
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=3008

# Database
DATABASE_URL=postgresql://thai_binh:thai_binh_dev@localhost:5432/thai_binh_training

# Connection Pool
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Authentication
BETTER_AUTH_SECRET=your-secret-key-must-be-at-least-32-characters-long

# VNPay Configuration
VNPAY_TMN_CODE=TEST12345
VNPAY_SECURE_SECRET=your-vnpay-secret-key-here
VNPAY_HOST=https://sandbox.vnpayment.vn
VNPAY_RETURN_URL=http://localhost:3008/api/payments/vnpay-return
VNPAY_IPN_URL=http://localhost:3008/api/payments/vnpay-ipn

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002